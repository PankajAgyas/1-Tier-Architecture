        <mxCell id="M27KGDmh28dz-DGsAx7X-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#36393d;" value="&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;The Terraform Block&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;terraform { }&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;In &lt;strong data-start=&quot;3&quot; data-end=&quot;16&quot; style=&quot;&quot;&gt;Terraform&lt;/strong&gt;, the &lt;code data-start=&quot;22&quot; data-end=&quot;36&quot; style=&quot;&quot;&gt;terraform {}&lt;/code&gt; block is used to configure core settings for Terraform&lt;/font&gt;&lt;/div&gt;" vertex="1">
